# Supabase Haupt-App (gleiches Projekt wie die Vico-Haupt-App – Auth + Zeiterfassung)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Lizenz-API – erforderlich für Standortabfrage, App-Name, Design
# Ohne diese Werte: Standort-Link wird nicht angezeigt (features.standortabfrage fehlt)
VITE_LICENSE_API_URL=https://your-license-portal.supabase.co/functions/v1
VITE_LICENSE_NUMBER=XXXX-XXXX-XXXX

# Optional: API-Key falls Lizenz-Edge-Function geschützt
# VITE_LICENSE_API_KEY=
