VITE_SUPABASE_URL=https://your-license-portal.supabase.co
VITE_SUPABASE_ANON_KEY=your-license-portal-anon-key

# Lizenz-API für Mandanten-Builds / Export (empfohlen = Edge, gleiches Projekt wie VITE_SUPABASE_URL)
# VITE_LICENSE_API_URL=https://your-license-portal.supabase.co/functions/v1
# VITE_LICENSE_API_KEY=optional (anon), wenn Edge JWT prüft

# Optional: GitHub Actions Übersicht (z. B. https://github.com/ORG/REPO/actions) für Links auf „Mandanten aktualisieren“
# VITE_GITHUB_ACTIONS_URL=

# Nur für lokales netlify dev / Legacy Netlify Functions (admin/netlify/functions)
# SUPABASE_LICENSE_PORTAL_URL=https://your-license-portal.supabase.co
# SUPABASE_LICENSE_PORTAL_SERVICE_ROLE_KEY=your-service-role-key
