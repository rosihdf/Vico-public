# Vorlage: Secrets für Edge Functions im MANDANTEN-Supabase-Projekt.
# Nicht committen mit echten Werten. Setzen z. B. per Dashboard oder:
#   supabase secrets set --env-file mandanten-edge-secrets.local.env --project-ref <MANDANT_REF>
#
# Öffentliche Basis-URLs ohne trailing slash.

PORTAL_URL=https://your-portal.pages.dev
APP_URL=https://your-main-app.pages.dev

# Optional, wenn E-Mail-Functions genutzt werden:
# RESEND_API_KEY=re_...
# RESEND_FROM=Vico <mail@example.com>
