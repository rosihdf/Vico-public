# Vorlage: Secrets für Edge Functions im MANDANTEN-Supabase-Projekt.
# Nicht committen mit echten Werten. Setzen z. B. per Dashboard oder:
#   supabase secrets set --env-file mandanten-edge-secrets.local.env --project-ref <MANDANT_REF>
#
# Öffentliche Basis-URLs ohne trailing slash.

PORTAL_URL=https://your-portal.pages.dev
APP_URL=https://your-main-app.pages.dev

# Optional, wenn Legacy-E-Mail-Functions genutzt werden (Fallback):
# RESEND_API_KEY=re_...
# RESEND_FROM=ArioVan <noreply@mail.amrtech.de>

# Digest → Lizenzportal (primärer Versand, gleiches Secret wie TENANT_SERVER_MAIL_SECRET im LP):
# LP_SUPABASE_URL=https://<lizenzportal-ref>.supabase.co
# LP_TENANT_ID=<uuid-des-mandanten-im-lizenzportal>
# LP_TENANT_SERVER_MAIL_SECRET=<mind. 24 zeichen, gleich wie LP TENANT_SERVER_MAIL_SECRET>

# Optional: Nutzungs-RPC auf LP spiegeln (bestehendes Muster):
# LP_SERVICE_ROLE_KEY=...

# Cron-Schutz für send-maintenance-reminder-digest:
# MAINTENANCE_DIGEST_CRON_SECRET=...
