# Kopiere diese Datei nach .env und trage deine Werte ein

# Supabase
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key

# Lizenz-API (Mandantenfähigkeit)
# Empfohlen (Cloudflare Pages + Supabase Edge): Basis ohne Slash am Ende → Aufrufe …/license, …/limit-exceeded
# VITE_LICENSE_API_URL=https://<lizenzportal-ref>.supabase.co/functions/v1
# Produktion ArioVan Lizenzportal (Beispiel, gleicher Wert wie in Pages-Env der Haupt-App):
# VITE_LICENSE_API_URL=https://ojryoosqwfbzlmdeywzs.supabase.co/functions/v1
# VITE_LICENSE_API_KEY=optional, nur wenn Edge Functions verify_jwt nutzen (meist Lizenzportal-anon)
# Legacy (Netlify Admin /api): VITE_LICENSE_API_URL=https://admin.example.com/api

# Arbeitszeitenportal (separates Frontend) – nur für Admin/Teamleiter sichtbar
# In Entwicklung z. B. http://localhost:5176
# VITE_ARBEITSZEIT_PORTAL_URL=http://localhost:5176

# Web Push (Standortanfrage-Benachrichtigungen) – optional
# VAPID-Public-Key generieren: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=dein-public-key
